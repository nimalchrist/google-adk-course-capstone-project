# ── OpenRouter (LLM provider) ─────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── PostgreSQL ────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DB=ecombot
PG_USER=ecombot
PG_PASSWORD=pg_secret

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_SESSION_TTL=3600

# ── Session backend (memory | redis | database) ──────────────────────────
SESSION_BACKEND=memory

# ── Day 08: MCP Server config ────────────────────────────────────────────
ORDERS_SERVER_HOST=127.0.0.1
ORDERS_SERVER_PORT=8766
INVENTORY_SERVER_HOST=127.0.0.1
INVENTORY_SERVER_PORT=8767
